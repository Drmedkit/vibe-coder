{
  "name": "vibe-coder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/build-runtime.mjs",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "node scripts/deploy-cloudflare.mjs",
    "upload": "node scripts/deploy-cloudflare.mjs upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:migrate:local": "wrangler d1 migrations apply DB --local",
    "cf:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:create-teacher": "node scripts/create-teacher.mjs",
    "db:backup": "wrangler d1 export DB --remote --output backups/vibe.sql"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@google/genai": "^2.11.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@phosphor-icons/react": "^2.1.10",
    "@preact/signals": "^2.9.3",
    "@uiw/react-codemirror": "^4.25.9",
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "esbuild": "^0.28.1",
    "howler": "^2.2.4",
    "jsonrepair": "^3.15.0",
    "marked": "^18.0.6",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "openai": "^6.32.0",
    "preact": "^10.29.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sucrase": "^3.35.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/howler": "^2.2.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wrangler": "^4.110.0"
  }
}
