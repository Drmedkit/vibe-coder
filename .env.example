# Local development only. Production secrets belong in Cloudflare Workers.

# Primary build + runtime text provider
XAI_API_KEY=

# Optional text-model fallback when XAI_API_KEY is not set
OPENROUTER_API_KEY=

# Build-time and runtime image generation
GOOGLE_AI_API_KEY=

# Optional model overrides
BUILD_MODEL=grok-4.3
RUNTIME_TEXT_MODEL=grok-4.3-mini
IMAGE_MODEL=imagen-4.0-fast-generate-001

# Optional production custom domain. Leave empty on workers.dev.
# With a wildcard route configured, approved projects use slug.example.com.
ROOT_DOMAIN=

# Optional operating limits
DAILY_CREATOR_CREDITS=100
RUNTIME_TEXT_DAILY_LIMIT=50
RUNTIME_IMAGE_DAILY_LIMIT=3
RATE_LIMIT_SALT=
VISITOR_HASH_SALT=

# Deterministic local builder; never enable this in production.
VIBE_FAKE_AI=0
